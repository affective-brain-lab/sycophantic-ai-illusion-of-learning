# PCA on the five AI tone ratings - Sycophancy Score 
items5 <- c("empathetic_1", "polite_1", "helpful_1", "blunt_1", "confrontational_1")
tone5 <- df_main %>%
  select(all_of(items5)) %>%
  na.omit() %>%
  mutate(across(everything(), as.numeric))

#KMO and Bartlett's test
print(KMO(tone5))
print(cortest.bartlett(cor(tone5, use = "pairwise.complete.obs"), n = nrow(tone5)))

#Eigenvalues (Kaiser criterion)
ev <- eigen(cor(tone5))$values
print(round(ev, 3))
k <- sum(ev > 1)
cat("Kaiser criterion → extract", k, "component(s)\n")

#pca
pca_result <- principal(
  r        = tone5,
  nfactors = k,
  rotate   = "none",    # unrotated; PC1 loadings reported in paper
  scores   = FALSE
)
print(pca_result, digits = 3, cut = 0, sort = FALSE)

#extract pc1 scores
