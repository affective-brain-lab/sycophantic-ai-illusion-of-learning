# 95% CI for partial correlation
pcor_ci <- function(r, n, k, conf.level = 0.95) {
  z     <- atanh(r)
  se    <- 1 / sqrt(n - k - 3)
  zcrit <- qnorm(1 - (1 - conf.level) / 2)
  c(lower = tanh(z - zcrit * se), upper = tanh(z + zcrit * se))
}
ci_pcor <- pcor_ci(res_pcor$estimate, res_pcor$n, k = 2)
cat("95% CI: [", round(ci_pcor["lower"], 2), ",", round(ci_pcor["upper"], 2), "]\n")


