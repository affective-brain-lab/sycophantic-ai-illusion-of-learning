#Supplementary Appendix: Regression Tables
truncate_num <- function(x, digits = 2) {
  ifelse(is.na(x), NA_real_, trunc(x * 10^digits) / 10^digits)
}
fmt_num_trunc <- function(x, digits = 2) {
  x2 <- truncate_num(x, digits)
  ifelse(is.na(x2), "", formatC(x2, format = "f", digits = digits))
}
fmt_p_trunc <- function(p) {
  case_when(
    is.na(p) ~ "",
    p < .001 ~ "<.001",
    TRUE     ~ sub("^0", "", formatC(truncate_num(p, 3), format = "f", digits = 3))
  )
}
# single regression table
make_reg_table <- function(model, title, rename_map) {
  
  pr2    <- rsq.partial(model, adj = FALSE)
  pr2_df <- tibble(term_pr2 = pr2$variable, partial_r2 = pr2$partial.rsq)
  ci_mat <- suppressMessages(confint(model))
  
  tab <- broom::tidy(model) %>%
    mutate(
      conf.low  = ci_mat[term, 1],
      conf.high = ci_mat[term, 2],
      term_pr2  = case_when(
        grepl("^domain", term)    ~ "domain",
        grepl("^Condition", term) ~ "Condition",
        TRUE                      ~ term
      )
    ) %>%
    left_join(pr2_df, by = "term_pr2") %>%
    mutate(
      predictor  = recode(term, !!!rename_map, .default = term),
      beta_ci    = paste0(fmt_num_trunc(estimate, 2), " [",
                          fmt_num_trunc(conf.low, 2), ", ",
                          fmt_num_trunc(conf.high, 2), "]"),
      p_value    = fmt_p_trunc(p.value),
      partial_r2 = ifelse(is.na(partial_r2), "", fmt_num_trunc(partial_r2, 2))
    ) %>%
    select(predictor, beta_ci, p_value, partial_r2)
  
  gt_tbl <- tab %>%
    gt() %>%
    tab_header(title = md(paste0("**", title, "**"))) %>%
    cols_label(predictor  = "",
               beta_ci    = md("**β [95% CI]**"),
               p_value    = md("**p-value**"),
               partial_r2 = md("**partial R²**")) %>%
    cols_width(predictor ~ px(100), beta_ci ~ px(90),
               p_value   ~ px(50),  partial_r2 ~ px(50)) %>%
    cols_align("left",   predictor) %>%
    cols_align("center", c(beta_ci, p_value, partial_r2)) %>%
    tab_style(style     = cell_text(weight = "bold"),
              locations = cells_column_labels(everything())) %>%
    tab_options(
      table.width                       = px(660),
      table.font.size                   = 12,
      heading.title.font.size           = 13,
      column_labels.border.top.width    = px(2),
      column_labels.border.bottom.width = px(2),
      table_body.hlines.width           = px(1),
      table.border.top.width            = px(2),
      table.border.bottom.width         = px(2)
    )
  
  grid.newpage()
  grid.draw(gt::as_gtable(gt_tbl))
}

