# Dissociation: perceived vs. actual competence
#Partial Pearson correlations:

df_syc     <- df_main %>% filter(condition == "sycophantic")
df_non_syc <- df_main %>% filter(condition == "non_sycophantic")

#Partial Pearson correlations (controlling for accuracy_pre & perceived_comp_pre)
res_syc <- pcor.test(
  x = df_syc$perceived_comp_post,
  y = df_syc$accuracy_post,
  z = df_syc[, c("accuracy_pre", "perceived_comp_pre")])
cat("Sycophantic – partial r =", round(res_syc$estimate, 3),
    "  p =", round(res_syc$p.value, 3), "\n")
res_non_syc <- pcor.test(
  x = df_non_syc$perceived_comp_post,
  y = df_non_syc$accuracy_post,
  z = df_non_syc[, c("accuracy_pre", "perceived_comp_pre")])
cat("Non-sycophantic – partial r =", round(res_non_syc$estimate, 3),
    "  p =", round(res_non_syc$p.value, 3), "\n")

#95% CIs for partial correlations (Fisher z-transform ± z_crit / sqrt(n - k - 3), back-transforme)
pcor_ci <- function(r, n, k, conf.level = 0.95) {
  z     <- atanh(r)
  se    <- 1 / sqrt(n - k - 3)          
  zcrit <- qnorm(1 - (1 - conf.level) / 2)
  c(lower = tanh(z - zcrit * se),
    upper = tanh(z + zcrit * se))}
k <- 2  
ci_syc     <- pcor_ci(res_syc$estimate,     res_syc$n,     k)
ci_non_syc <- pcor_ci(res_non_syc$estimate, res_non_syc$n, k)
cat("Sycophantic 95% CI:     [", round(ci_syc[1], 2), ",", round(ci_syc[2], 2), "]\n")
cat("Non-sycophantic 95% CI: [", round(ci_non_syc[1], 2), ",", round(ci_non_syc[2], 2), "]\n")

# Fisher's r-to-z test comparing the two partial correlations
#Note: Using atanh(): idiomatic R equivalent of the 0.5*log((1+r)/(1-r)) transform).
r_syc     <- res_syc$estimate
r_non_syc <- res_non_syc$estimate
n_syc     <- res_syc$n
n_non_syc <- res_non_syc$n
#Fisher z-transform for sycophantic condition
z_syc     <- atanh(r_syc)      
#Fisher z-transform for non-sycophantic condition
z_non_syc <- atanh(r_non_syc) 
SE_diff   <- sqrt(1 / (n_syc - 3) + 1 / (n_non_syc - 3))
z_diff    <- (z_syc - z_non_syc) / SE_diff
p_fisher  <- 2 * (1 - pnorm(abs(z_diff)))
cat("Fisher's r-to-z: z =", round(z_diff, 2), "  p =", round(p_fisher, 3), "\n")

