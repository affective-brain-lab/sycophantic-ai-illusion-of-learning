label_txt <- sprintf("\u0394r[partial]:  z = %.2f", z_diff)

ggplot(df_resid_all, aes(x = acc_resid, y = pc_resid)) +
  geom_jitter(width = 0.05, alpha = 0.35, size = 0.6, color = "black") +
  geom_smooth(aes(color = Condition, fill = Condition),
              method = "lm", se = TRUE, alpha = 0.2, linewidth = 1) +
  annotate("text", x = 0.10, y = 30,
           label = label_txt, hjust = 1, size = 5, fontface = "bold") +
  scale_color_manual(values = c("Non-sycophantic AI" = col_non_syc,
                                "Sycophantic AI"     = col_syc)) +
  scale_fill_manual(values  = c("Non-sycophantic AI" = col_non_syc,
                                "Sycophantic AI"     = col_syc)) +
  labs(
    x = paste0("<b style='font-weight:900;'>Competence (Residuals)</b><br>",
               "<span style='font-size:11pt;'>(transfer exam score, controlling for ",
               "initial exam & baseline perceived competence)</span>"),
    y = paste0("<b style='font-weight:900;'>Perceived Competence (Residuals)</b><br>",
               "<span style='font-size:11pt;'>(post AI interaction, controlling for ",
               "initial exam & baseline perceived competence)</span>")
  ) +
  theme_classic() +
  theme(
    axis.text       = element_text(size = 20),
    axis.title.x    = element_markdown(size = 30, lineheight = 0.1),
    axis.title.y    = element_markdown(size = 30, lineheight = 0.1),
    legend.title    = element_blank(),
    legend.text     = element_text(size = 22),
    legend.position = "right"
  )

